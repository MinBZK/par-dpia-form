# Stage 1: build
FROM node:22-alpine AS build

RUN corepack enable && corepack prepare pnpm@latest --activate

WORKDIR /app

# Copy workspace config en package manifests
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml* ./
COPY packages/assessment-core/package.json packages/assessment-core/
COPY apps/standalone-form/package.json apps/standalone-form/
COPY apps/boekhouding-backend/package.json apps/boekhouding-backend/
COPY apps/boekhouding-frontend/package.json apps/boekhouding-frontend/

# Install all dependencies (inclusief devDependencies voor build)
RUN pnpm install --frozen-lockfile || pnpm install

# Copy source
COPY packages/assessment-core/ packages/assessment-core/
COPY sources/generated/ sources/generated/
COPY sources/datamodel/ sources/datamodel/
COPY apps/standalone-form/ apps/standalone-form/
COPY apps/boekhouding-frontend/ apps/boekhouding-frontend/

# Build standalone form (viteSingleFile → alles inlined in index.html)
WORKDIR /app/apps/standalone-form
RUN npx vite build

RUN mkdir -p /app/apps/boekhouding-frontend/public && \
    cp /app/apps/boekhouding-frontend/node_modules/@nl-rvo/assets/images/favicon/favicon.ico \
       /app/apps/boekhouding-frontend/public/favicon.ico

# Build frontend SPA
WORKDIR /app/apps/boekhouding-frontend
RUN npx vite build

# Stage 2: unprivileged nginx voor statische bestanden
FROM nginxinc/nginx-unprivileged:stable-alpine-slim

# Hoofd-SPA
COPY --from=build /app/apps/boekhouding-frontend/dist /usr/share/nginx/html

# Standalone invulhulp op /invulhulpen/ (index.html + favicon)
COPY --from=build /app/apps/standalone-form/dist/ /usr/share/nginx/html/invulhulpen/

# Nginx configuratie
COPY containers/frontend/nginx.conf /etc/nginx/nginx.conf
COPY containers/frontend/default.conf /etc/nginx/conf.d/default.conf

COPY containers/frontend/config.json.template /etc/nginx/config.json.template
COPY --chmod=755 containers/frontend/entrypoint.sh /entrypoint.sh

ENV OIDC_URL=http://localhost:8080
ENV OIDC_REALM=assessment-boekhouding
ENV OIDC_CLIENT_ID=boekhouding-frontend
ENV STANDALONE_URL=/invulhulpen/

EXPOSE 8080
ENTRYPOINT ["/entrypoint.sh"]
