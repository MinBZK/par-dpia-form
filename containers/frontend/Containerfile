# Stage 1: build
FROM node:26-alpine@sha256:e88a35be04478413b7c71c455cd9865de9b9360e1f43456be5951032d7ac1a66 AS build

RUN corepack enable && corepack prepare pnpm@11.13.0+sha512.88d94724d8f2e6c186744a5584c6e59ecac869ec7ba15e9cb4cd628e8dc7066820b2481d8ee3b51ea8da323a7378068aa58c556a3720d32b7c20a051d088363a --activate

WORKDIR /app

# Copy workspace config en package manifests
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml* ./
COPY packages/assessment-core/package.json packages/assessment-core/
COPY apps/standalone-form/package.json apps/standalone-form/
COPY apps/boekhouding-backend/package.json apps/boekhouding-backend/
COPY apps/boekhouding-frontend/package.json apps/boekhouding-frontend/

# Install all dependencies (inclusief devDependencies voor build)
RUN pnpm install --frozen-lockfile || pnpm install

ARG GIT_SHA=dev

# Copy source
COPY packages/assessment-core/ packages/assessment-core/
COPY sources/generated/ sources/generated/
COPY sources/assets/ sources/assets/
COPY apps/standalone-form/ apps/standalone-form/
COPY apps/boekhouding-frontend/ apps/boekhouding-frontend/

# Build standalone form (viteSingleFile → alles inlined in index.html)
WORKDIR /app/apps/standalone-form
RUN npx vite build

RUN mkdir -p /app/apps/boekhouding-frontend/public && \
    cp /app/apps/boekhouding-frontend/node_modules/@nl-rvo/assets/images/favicon/favicon.ico \
       /app/apps/boekhouding-frontend/public/favicon.ico

# Build frontend SPA
WORKDIR /app/apps/boekhouding-frontend
RUN npx vite build

RUN printf '{"version":"dev","commit":"%s","channel":"acceptatie"}\n' "$(printf '%s' "$GIT_SHA" | cut -c1-7)" > dist/version.json

# Stage 2: unprivileged nginx voor statische bestanden
FROM nginxinc/nginx-unprivileged:stable-alpine-slim@sha256:e88d990b349df8cf4aa82f16642d7a23375016638c9ace4e5c6ca25028e62e65

# Hoofd-SPA
COPY --from=build /app/apps/boekhouding-frontend/dist /usr/share/nginx/html

# Standalone invulhulp op /zonder-account/ (single-file, favicon inlined)
COPY --from=build /app/apps/standalone-form/dist/index.html /usr/share/nginx/html/zonder-account/index.html

# Nginx configuratie (containers/frontend/nginx/ → /etc/nginx/)
COPY containers/frontend/nginx/nginx.conf /etc/nginx/nginx.conf
COPY containers/frontend/nginx/default.conf /etc/nginx/conf.d/default.conf
COPY containers/frontend/nginx/snippets/ /etc/nginx/snippets/
# Per-build hashed CSP for the standalone, generated by its Vite build.
COPY --from=build /app/apps/standalone-form/dist/csp-standalone.conf /etc/nginx/snippets/csp-standalone.conf

COPY containers/frontend/nginx/config.json.template /etc/nginx/config.json.template
COPY --chmod=755 containers/frontend/entrypoint.sh /entrypoint.sh

ENV OIDC_URL=http://localhost:8080
ENV OIDC_REALM=invulhulpen
ENV OIDC_PUBLIC_CLIENT_ID=boekhouding-frontend
ENV STANDALONE_URL=/zonder-account/

EXPOSE 8080
ENTRYPOINT ["/entrypoint.sh"]
