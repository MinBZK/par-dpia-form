FROM node:26-alpine@sha256:e88a35be04478413b7c71c455cd9865de9b9360e1f43456be5951032d7ac1a66

RUN corepack enable && corepack prepare pnpm@11.13.0+sha512.88d94724d8f2e6c186744a5584c6e59ecac869ec7ba15e9cb4cd628e8dc7066820b2481d8ee3b51ea8da323a7378068aa58c556a3720d32b7c20a051d088363a --activate

# Python toolchain for generating sources/generated/*.json from the YAML
# sources — mirrors the CI step in .github/workflows/test.yaml.
RUN apk add --no-cache python3 py3-pip py3-yaml py3-jsonschema

WORKDIR /app

# Copy workspace config and manifests
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml* ./
COPY packages/assessment-core/package.json packages/assessment-core/
COPY apps/standalone-form/package.json apps/standalone-form/
COPY apps/boekhouding-backend/package.json apps/boekhouding-backend/
COPY apps/boekhouding-frontend/package.json apps/boekhouding-frontend/

RUN pnpm install --frozen-lockfile || pnpm install

# Generate the assessment-definition JSONs so the frontend can resolve
# `import('../../../../sources/generated/DPIA.json')` on the first Vite
# transform. HMR volume mounts don't overwrite these — fine for dev use.
COPY script/ /app/script/
COPY schemas/ /app/schemas/
COPY sources/ /app/sources/
RUN mkdir -p /app/sources/generated && \
    python3 /app/script/run_all.py \
      --schema /app/schemas/assessment-definition.v2.schema.json \
      --source /app/sources/prescan.yaml \
      --begrippen-yaml /app/sources/begrippenkader_dpia.yaml \
      --output-json /app/sources/generated/PreScanDPIA.json && \
    python3 /app/script/run_all.py \
      --schema /app/schemas/assessment-definition.v2.schema.json \
      --source /app/sources/dpia.yaml \
      --begrippen-yaml /app/sources/begrippenkader_dpia.yaml \
      --output-json /app/sources/generated/DPIA.json && \
    python3 /app/script/run_all.py \
      --schema /app/schemas/assessment-definition.v2.schema.json \
      --source /app/sources/iama.yaml \
      --begrippen-yaml /app/sources/begrippenkader_iama.yaml \
      --output-json /app/sources/generated/IAMA.json \
      --definitions-once-per-page

WORKDIR /app
EXPOSE 5174
CMD ["pnpm", "--filter", "@overheid-assessment/boekhouding-frontend", "dev"]
