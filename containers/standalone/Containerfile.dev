FROM node:22-alpine@sha256:9385cd9f3001dfc3431e8ead12c43e9e1f87cc1b9b5c6cfd0f73865d405b27c4

RUN corepack enable && corepack prepare pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be --activate

RUN apk add --no-cache python3 py3-pip py3-yaml py3-jsonschema

WORKDIR /app

# Copy workspace config and manifests
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml* ./
COPY packages/assessment-core/package.json packages/assessment-core/
COPY apps/standalone-form/package.json apps/standalone-form/

RUN pnpm install --frozen-lockfile || pnpm install

COPY script/ /app/script/
COPY schemas/ /app/schemas/
COPY sources/ /app/sources/
RUN python3 /app/script/build_sources.py \
      --manifest /app/sources/manifest.yaml \
      --sources-dir /app/sources \
      --schema /app/schemas/assessment-definition.v2.schema.json \
      --generated-dir /app/sources/generated

WORKDIR /app
EXPOSE 5175
CMD ["pnpm", "--filter", "standalone-form", "dev"]
