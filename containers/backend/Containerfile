# Stage 1: install dependencies and build
FROM node:26-alpine@sha256:e88a35be04478413b7c71c455cd9865de9b9360e1f43456be5951032d7ac1a66 AS build

RUN corepack enable && corepack prepare pnpm@11.13.0+sha512.88d94724d8f2e6c186744a5584c6e59ecac869ec7ba15e9cb4cd628e8dc7066820b2481d8ee3b51ea8da323a7378068aa58c556a3720d32b7c20a051d088363a --activate

WORKDIR /app

# Copy workspace config and package manifests
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml* ./
COPY apps/boekhouding-backend/package.json apps/boekhouding-backend/

# Install all dependencies (including devDependencies for build)
RUN pnpm install --frozen-lockfile || pnpm install

# Copy source
COPY apps/boekhouding-backend/ apps/boekhouding-backend/

# Compile TypeScript to JavaScript
WORKDIR /app/apps/boekhouding-backend
RUN npx tsc

# Stage 2: production image with only runtime dependencies
FROM node:26-alpine@sha256:e88a35be04478413b7c71c455cd9865de9b9360e1f43456be5951032d7ac1a66

RUN corepack enable && corepack prepare pnpm@11.13.0+sha512.88d94724d8f2e6c186744a5584c6e59ecac869ec7ba15e9cb4cd628e8dc7066820b2481d8ee3b51ea8da323a7378068aa58c556a3720d32b7c20a051d088363a --activate

WORKDIR /app

# Copy workspace config and package manifests
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml* ./
COPY apps/boekhouding-backend/package.json apps/boekhouding-backend/

# Install production dependencies only
RUN pnpm install --frozen-lockfile --prod || pnpm install --prod

# Copy compiled output and drizzle migrations
COPY --from=build /app/apps/boekhouding-backend/dist apps/boekhouding-backend/dist
COPY --from=build /app/apps/boekhouding-backend/drizzle apps/boekhouding-backend/drizzle

# Canonical output schema — read at startup by validateState.ts (resolved at /app/schemas).
COPY schemas/assessment-output.v2.schema.json schemas/assessment-output.v2.schema.json

WORKDIR /app/apps/boekhouding-backend

ARG GIT_SHA=dev
ENV APP_COMMIT=$GIT_SHA

USER 1000

CMD ["sh", "-c", "node dist/db/migrate.js && node dist/index.js"]
