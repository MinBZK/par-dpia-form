{
  "private": true,
  "scripts": {
    "dev": "pnpm --filter standalone-form dev",
    "dev:backend": "pnpm --filter @overheid-assessment/boekhouding-backend dev",
    "dev:frontend": "pnpm --filter @overheid-assessment/boekhouding-frontend dev",
    "build:standalone": "pnpm --filter standalone-form build",
    "build:backend": "pnpm --filter @overheid-assessment/boekhouding-backend build",
    "build:frontend": "pnpm --filter @overheid-assessment/boekhouding-frontend build",
    "type-check": "pnpm --filter standalone-form type-check",
    "lint": "pnpm --filter standalone-form lint",
    "format": "pnpm --filter standalone-form format",
    "db:generate": "pnpm --filter @overheid-assessment/boekhouding-backend db:generate",
    "db:migrate": "pnpm --filter @overheid-assessment/boekhouding-backend db:migrate",
    "check:csp": "node --test scripts/check-inline-styles.test.mjs && node scripts/check-inline-styles.mjs",
    "test:e2e": "node tests/e2e/sync.spec.mjs",
    "test:coverage": "pnpm -r --if-present test:coverage"
  },
  "dependencies": {
    "jexl": "^2.3.0"
  },
  "devDependencies": {
    "playwright": "1.61.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
